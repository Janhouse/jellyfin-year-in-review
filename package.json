{
	"name": "jellyfin-year-in-review",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --bun run next dev --turbopack",
		"build": "bun --bun run next build",
		"start": "bun --bun run  next start",
		"typecheck": "bun --bun next typegen && bun --bun tsc --noEmit",
		"lint": "bun --bun run biome check .",
		"lint:fix": "bun --bun run biome check --write .",
		"lint:ci": "biome ci .",
		"format": "bun --bun run biome format --write ."
	},
	"dependencies": {
		"@radix-ui/react-avatar": "^1.2.2",
		"@radix-ui/react-progress": "^1.1.12",
		"@radix-ui/react-select": "^2.3.3",
		"@radix-ui/react-slot": "^1.3.0",
		"@tailwindcss/postcss": "^4.3.2",
		"better-auth": "^1.6.23",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cron": "^4.4.0",
		"framer-motion": "^12.42.2",
		"js-confetti": "^0.13.1",
		"lucide-react": "^1.24.0",
		"next": "^16.2.10",
		"nodemailer": "^9.0.3",
		"postcss": "^8.5.18",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@types/bun": "^1.3.14",
		"@types/cron": "^2.4.3",
		"@types/node": "^26.1.1",
		"@types/nodemailer": "^8.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"typescript": "^6.0.3"
	}
}
